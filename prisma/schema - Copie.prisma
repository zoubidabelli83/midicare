generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  role         Role          @default("SEEKER")
  status       AccountStatus @default("PENDING")
  isVerified   Boolean       @default(false)
  name         String
  phone        String
  avatarUrl    String?
  lat          Float?
  lng          Float?
  createdAt    DateTime      @default(now())
  applications Application[]
  demands      Demand[]      @relation("SeekerDemands")
}

model Demand {
  id           String        @id @default(cuid())
  title        String
  description  String
  lat          Float
  lng          Float
  status       DemandStatus  @default("OPEN")
  seekerId     String
  createdAt    DateTime      @default(now())
  applications Application[]
  seeker       User          @relation("SeekerDemands", fields: [seekerId], references: [id])
}

model Application {
  id         String   @id @default(cuid())
  message    String
  status     String   @default("PENDING")
  providerId String
  demandId   String
  createdAt  DateTime @default(now())
  demand     Demand   @relation(fields: [demandId], references: [id])
  provider   User     @relation(fields: [providerId], references: [id])
}

enum Role {
  ADMIN
  SEEKER
  PROVIDER
}

enum AccountStatus {
  PENDING
  ACTIVE
  BANNED
}

enum DemandStatus {
  OPEN
  CLOSED
}
