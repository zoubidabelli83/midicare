generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String
  role             Role          @default("SEEKER")
  status           AccountStatus @default("PENDING")
  isVerified       Boolean       @default(false)
  name             String
  phone            String
  avatarUrl        String?
  lat              Float?
  lng              Float?
  createdAt        DateTime      @default(now())
  hourlyRate       Float?
  yearsExperience  Int?
  specialties      String?
  availability     String?
  certifications   String?
  bio              String?
  serviceRadius    Float?        @default(10)
  averageRating    Float?        @default(0) @map("average_rating")
  totalReviews     Int           @default(0) @map("total_reviews")
  resetToken       String?       @unique
  resetTokenExpiry DateTime?
  applications     Application[] @relation("ProviderApplications")
  demands          Demand[]      @relation("SeekerDemands")
  reviewsReceived  Review[]      @relation("ReviewsReceived")
  reviewsGiven     Review[]      @relation("ReviewsGiven")
}

model Demand {
  id           String        @id @default(cuid())
  title        String
  description  String
  lat          Float
  lng          Float
  status       DemandStatus  @default("OPEN")
  seekerId     String
  createdAt    DateTime      @default(now())
  applications Application[]
  seeker       User          @relation("SeekerDemands", fields: [seekerId], references: [id])
  reviews      Review?
}

model Application {
  id         String   @id @default(cuid())
  message    String
  status     String   @default("PENDING")
  providerId String
  demandId   String
  createdAt  DateTime @default(now())
  demand     Demand   @relation(fields: [demandId], references: [id])
  provider   User     @relation("ProviderApplications", fields: [providerId], references: [id])
  review     Review?
}

model Review {
  id            String       @id @default(cuid())
  rating        Int
  comment       String?
  reviewerId    String
  revieweeId    String
  demandId      String?      @unique
  applicationId String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  application   Application? @relation(fields: [applicationId], references: [id])
  demand        Demand?      @relation(fields: [demandId], references: [id])
  reviewee      User         @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  reviewer      User         @relation("ReviewsGiven", fields: [reviewerId], references: [id])

  @@index([revieweeId])
}

enum Role {
  ADMIN
  SEEKER
  PROVIDER
}

enum AccountStatus {
  PENDING
  ACTIVE
  BANNED
}

enum DemandStatus {
  OPEN
  CLOSED
}
